#!/usr/bin/env bash

# Script path constants
SCRIPT_PATH="$(readlink -f "$0")"
SCRIPT_ROOT="$(dirname "$SCRIPT_PATH")"
PROJECT_ROOT="$SCRIPT_ROOT/.."

# Clear Gradle wrapper cache FIRST, before any gradle commands
rm -rf ~/.gradle/wrapper/dists/gradle-*

# Important project paths
RES_DIR="$PROJECT_ROOT/app/src/main/res"
RAW_DIR="$RES_DIR/raw"
INPUT_DIR="$SCRIPT_ROOT/input"
OUTPUT_DIR="$SCRIPT_ROOT/output"
APK_OUTPUT_DIR="$PROJECT_ROOT/app/build/outputs/apk/release"
AAB_OUTPUT_DIR="$PROJECT_ROOT/app/build/outputs/bundle/release"

# Paths to mutable files
CONFIG="$RES_DIR/values/config.xml"
ROM="$RAW_DIR/rom"

# Icon-related paths
MIPMAP_DENSITIES=(mipmap-mdpi mipmap-hdpi mipmap-xhdpi mipmap-xxhdpi mipmap-xxxhdpi)
ADAPTIVE_ICON_DIR="$RES_DIR/mipmap-anydpi-v26"
ICON_BACKUP_DIR="$(mktemp -d)"

# Supported ABIs
ABIS=(armeabi-v7a arm64-v8a x86 x86_64 universal)

# Log a message
log() {
	echo -e "\e[36m > $*\e[0m"
}

# Log a non-fatal error
err() {
	echo -e "\e[31m > $*\e[0m"
}

# Run gradle commands from proper directory
gradlew() {
	cd "$PROJECT_ROOT" || return
	bash gradlew "$@"
}

# Get a value from the config file given a name
config_val() {
	local name="$1"

	grep "name=\"$1\"" "$CONFIG" | grep -o -P '(?<=>).*(?=</)'
}

# Replace a value in the config file given a name and a new value
config_replace() {
	local name="$1"
	local value="$2"

	xmlstarlet ed -L -u "/resources/string[@name='$name']" -v "$value" "$CONFIG"
}

# Snapshot the project's default launcher icon assets so we can restore
# them between ROM batches that don't provide a custom icon
backup_default_icons() {
	local density

	for density in "${MIPMAP_DENSITIES[@]}"
	do
		mkdir -p "$ICON_BACKUP_DIR/$density"
		[[ -f "$RES_DIR/$density/ic_launcher.png" ]] && \
			cp "$RES_DIR/$density/ic_launcher.png" "$ICON_BACKUP_DIR/$density/ic_launcher.png"
		[[ -f "$RES_DIR/$density/ic_launcher_round.png" ]] && \
			cp "$RES_DIR/$density/ic_launcher_round.png" "$ICON_BACKUP_DIR/$density/ic_launcher_round.png"
	done

	if [[ -d "$ADAPTIVE_ICON_DIR" ]]
	then
		mkdir -p "$ICON_BACKUP_DIR/mipmap-anydpi-v26"
		cp "$ADAPTIVE_ICON_DIR"/*.xml "$ICON_BACKUP_DIR/mipmap-anydpi-v26/" 2>/dev/null
	fi
}

# Restore the project's default launcher icon (used before every subdir,
# so a custom icon from one batch doesn't leak into the next)
restore_default_icons() {
	local density

	for density in "${MIPMAP_DENSITIES[@]}"
	do
		mkdir -p "$RES_DIR/$density"
		[[ -f "$ICON_BACKUP_DIR/$density/ic_launcher.png" ]] && \
			cp "$ICON_BACKUP_DIR/$density/ic_launcher.png" "$RES_DIR/$density/ic_launcher.png"
		[[ -f "$ICON_BACKUP_DIR/$density/ic_launcher_round.png" ]] && \
			cp "$ICON_BACKUP_DIR/$density/ic_launcher_round.png" "$RES_DIR/$density/ic_launcher_round.png"
	done

	rm -rf "$ADAPTIVE_ICON_DIR"
	if [[ -d "$ICON_BACKUP_DIR/mipmap-anydpi-v26" ]]
	then
		mkdir -p "$ADAPTIVE_ICON_DIR"
		cp "$ICON_BACKUP_DIR/mipmap-anydpi-v26"/*.xml "$ADAPTIVE_ICON_DIR/" 2>/dev/null
	fi
}

# Look for an icon file (icon.png/.jpg/.jpeg/.webp, case-insensitive) in a
# given payload subdirectory. Prints the path if found.
find_icon() {
	local dir="$1"
	local f
	local fname
	local fname_lower

	for f in "$dir"/*
	do
		[[ ! -f "$f" ]] && continue
		fname="$(basename -- "$f")"
		fname_lower="${fname,,}"

		case "$fname_lower" in
			icon.png|icon.jpg|icon.jpeg|icon.webp)
				echo "$f"
				return
				;;
		esac
	done
}

# Check if a filename (case-insensitive) is a reserved payload asset
# (config file or custom icon) rather than an actual ROM
is_reserved_asset() {
	local fname_lower="${1,,}"

	case "$fname_lower" in
		config.xml|icon.png|icon.jpg|icon.jpeg|icon.webp)
			return 0
			;;
		*)
			return 1
			;;
	esac
}

# Install a custom launcher icon, overriding the project default for the
# ROMs currently being built. Removes the adaptive icon definition so the
# raster replacement isn't masked out on API 26+.
apply_custom_icon() {
	local icon="$1"
	local density

	for density in "${MIPMAP_DENSITIES[@]}"
	do
		mkdir -p "$RES_DIR/$density"
		cp "$icon" "$RES_DIR/$density/ic_launcher.png"
		cp "$icon" "$RES_DIR/$density/ic_launcher_round.png"
	done

	rm -rf "$ADAPTIVE_ICON_DIR"
}

# Make sure necessary folders are here
prepare_env() {
	local abi

	# Create raw directory if missing
	[[ ! -d "$RAW_DIR" ]] && mkdir -p "$RAW_DIR"

	# Create output ABI folders
	for abi in "${ABIS[@]}" aab
	do
		mkdir -p "$OUTPUT_DIR/$abi"
	done

	# Snapshot the default launcher icon before anything modifies it
	backup_default_icons
}

# Build one package
compile() {
	gradlew assembleRelease
	gradlew bundleRelease
}

build_inputs() {
	local subdir
	local rom
	local filename
	local romname
	local romid
	local output_filename
	local found_any=false
	local icon_file

	for subdir in "$INPUT_DIR"/*
	do
		# Skip invalid directories
		[[ ! -f "$subdir/config.xml" ]] && continue
		found_any=true

		# Clean existing cores
		log "Cleaning working directory..."
		cp "$subdir/config.xml" "$CONFIG"
		gradlew clean

		# Reset to the default icon, then apply a custom one if this
		# batch's payload folder included icon.png/.jpg/.jpeg/.webp
		restore_default_icons
		icon_file="$(find_icon "$subdir")"
		if [[ -n "$icon_file" ]]
		then
			log "Applying custom icon: $(basename -- "$icon_file")"
			apply_custom_icon "$icon_file"
		else
			log "No custom icon found for this batch, using default"
		fi

		for rom in "$subdir"/*
		do
			filename="$(basename -- "$rom")"

			# Skip config file and icon file; not ROMs
			is_reserved_asset "$filename" && continue

			# Escape issue characters
			romname="${filename%.*}"
			romname="$(xmlstarlet esc "$romname")"
			romname="${romname//\"/\\\"}"
			romname="${romname//\'/\\\'}"

			# Alphanumeric id
			romid="${romname// /_}"
			romid="${romname//[^A-Za-z0-9_]/}"
			romid="${romid,,}"			

			# Assert valid romid
			if [[ ! "$romid" =~ ^[a-z] ]]
			then
				err "$romid must start with a letter! Skipping..."
				continue
			fi

			# Update config with this info
			config_replace "config_id" "$romid"
			config_replace "config_name" "$romname"
			core="$(config_val "config_core")"

			# File name of output excluding extension
			output_filename="${core}_${romid}"

			# Skip build if already built
			[[ -f "$OUTPUT_DIR/aab/$output_filename.aab" ]] && continue

			# Copy rom to build directory
			cp "$rom" "$ROM"

			log "----- BUILDING -----"
			log "FILENAME:\t$filename..."
			log "ROMNAME:\t$romname"
			log "ROMID:\t$romid"
			log "CORE:\t$core"

			compile

			log "Copying outputs..."

			# Copy output APKs
			for abi in "${ABIS[@]}"
			do
				cp "$APK_OUTPUT_DIR/app-$abi-release.apk" "$OUTPUT_DIR/$abi/$output_filename.apk"		
			done

			# Copy output aab
			cp "$AAB_OUTPUT_DIR/app-release.aab" "$OUTPUT_DIR/aab/$output_filename.aab"
		
			log "Done!"
			echo
		done
	done

	# Nothing matched at the top level of $INPUT_DIR - try to auto-fix
	# one extra level of nesting (e.g. payload zip contained a wrapping
	# folder around the actual core subdirectories) before giving up.
	if [[ "$found_any" == false ]]
	then
		err "No config.xml found directly under $INPUT_DIR"
		err "Checking for an extra layer of nesting from the payload zip..."

		local nested
		local flattened=false
		for nested in "$INPUT_DIR"/*/
		do
			[[ ! -d "$nested" ]] && continue

			# Does this directory itself contain subdirs with config.xml?
			local inner
			for inner in "$nested"*/
			do
				if [[ -f "$inner/config.xml" ]]
				then
					log "Found nested config.xml under $inner - flattening..."
					mv "$inner" "$INPUT_DIR/"
					flattened=true
				fi
			done
		done

		if [[ "$flattened" == true ]]
		then
			log "Retrying build after flattening nested input directories..."
			build_inputs
		else
			err "ERROR: No valid config.xml found anywhere in $INPUT_DIR (even one level deep)."
			err "Expected structure:"
			err "  autogen/input/<core-name>/config.xml"
			err "  autogen/input/<core-name>/<rom file>"
			err "Actual contents of $INPUT_DIR:"
			find "$INPUT_DIR" -maxdepth 3 | sed 's/^/  /' >&2
			exit 1
		fi
	fi
}

prepare_env
build_inputs